generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum StudentCardStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(ADMIN)
  isActive     Boolean       @default(true)
  sessions     Session[]
  publications Publication[] @relation("PublicationAuthor")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Publication {
  id             String             @id @default(cuid())
  title          String
  slug           String             @unique
  summary        String
  content        String
  coverImage     String?
  category       String?
  authorName     String?
  status         PublicationStatus  @default(DRAFT)
  isArchived     Boolean            @default(false)
  featuredOnHome Boolean            @default(false)
  publishedAt    DateTime?
  createdById    String?
  createdBy      User?              @relation("PublicationAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  gallery        PublicationImage[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
  @@index([isArchived])
  @@index([featuredOnHome])
  @@index([publishedAt])
}

model PublicationImage {
  id            String      @id @default(cuid())
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  imageUrl      String
  caption       String?
  displayOrder  Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([publicationId])
}

model Story {
  id           String   @id @default(cuid())
  name         String
  photo        String?
  testimonial  String
  fullStory    String?
  course       String?
  institution  String?
  achievement  String?
  year         Int?
  displayOrder Int      @default(0)
  published    Boolean  @default(false)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published])
  @@index([featured])
  @@index([displayOrder])
}

model Partner {
  id              String   @id @default(cuid())
  name            String
  logo            String?
  description     String
  partnershipType String?
  externalLink    String?
  isActive        Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

model GalleryAlbum {
  id           String         @id @default(cuid())
  title        String
  description  String?
  category     String?
  eventDate    DateTime?
  featured     Boolean        @default(false)
  published    Boolean        @default(false)
  displayOrder Int            @default(0)
  images       GalleryImage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([published])
  @@index([featured])
  @@index([displayOrder])
}

model GalleryImage {
  id           String       @id @default(cuid())
  albumId      String
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  imageUrl     String
  caption      String?
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())

  @@index([albumId])
}

model Indicator {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  value        Int
  suffix       String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@index([isActive])
}

model PageBlock {
  id                String   @id @default(cuid())
  key               String   @unique
  section           String
  title             String?
  subtitle          String?
  body              String?
  ctaPrimaryLabel   String?
  ctaPrimaryHref    String?
  ctaSecondaryLabel String?
  ctaSecondaryHref  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  fileName  String
  mimeType  String
  size      Int
  bytes     Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model StudentCard {
  id              String            @id @default(cuid())
  fullName        String
  photo           String?
  enrollment      String
  course          String
  unit            String
  cardCode        String            @unique
  validityDate    DateTime
  issueDate       DateTime
  status          StudentCardStatus @default(ACTIVE)
  notes           String?
  cpf             String?
  birthDate       DateTime?
  classGroup      String?
  level           String?
  validationToken String            @unique
  responsibleName String?
  responsibleRole String?
  isArchived      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([isArchived])
  @@index([validityDate])
}
